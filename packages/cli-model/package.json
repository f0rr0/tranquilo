{
  "name": "@tranquilo/cli-model",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./agent-catalog": "./src/agent-catalog.ts",
    "./release-metadata": "./src/release-metadata.ts"
  },
  "scripts": {
    "lint": "ultracite check .",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
